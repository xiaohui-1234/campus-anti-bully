page {
  min-height: 100%;
  background: #f5f7f6;
  color: #263238;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 40;
  background: rgba(255, 255, 255, 0.98);
  box-sizing: border-box;
  border-bottom: 1rpx solid #edf1f2;
}

.custom-nav-title {
  height: 32px;
  line-height: 32px;
  padding-left: 32rpx;
  padding-right: 32rpx;
  text-align: center;
  color: #1d2b2f;
  font-size: 32rpx;
  font-weight: 700;
  box-sizing: border-box;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 40rpx 28rpx calc(40rpx + env(safe-area-inset-bottom));
}

.page-title {
  font-size: 42rpx;
  font-weight: 800;
  color: #1d2b2f;
  margin: 0 0 8rpx;
}

.page-subtitle {
  color: #77858a;
  font-size: 25rpx;
  line-height: 1.5;
  margin-bottom: 24rpx;
}

.panel {
  background: #ffffff;
  border-radius: 22rpx;
  box-shadow: 0 8rpx 26rpx rgba(33, 54, 59, 0.045);
  padding: 24rpx;
  box-sizing: border-box;
}

.input {
  height: 84rpx;
  border-radius: 18rpx;
  background: #eef4f2;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.search-bar {
  height: 84rpx;
  border-radius: 22rpx;
  background: #eef4f2;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  box-sizing: border-box;
}

.search-icon {
  width: 28rpx;
  height: 28rpx;
  border: 4rpx solid #8aa19f;
  border-radius: 50%;
  position: relative;
  box-sizing: border-box;
  flex: 0 0 auto;
}

.search-icon::after {
  content: "";
  position: absolute;
  width: 14rpx;
  height: 4rpx;
  border-radius: 4rpx;
  background: #8aa19f;
  right: -12rpx;
  bottom: -7rpx;
  transform: rotate(45deg);
}

.search-input {
  flex: 1;
  height: 84rpx;
  font-size: 27rpx;
  color: #263238;
}

.button {
  height: 84rpx;
  border-radius: 22rpx;
  background: #0f8b8d;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  box-sizing: border-box;
  transition: opacity 0.15s ease;
}

.button:active {
  opacity: 0.78;
}

.button.secondary {
  background: #e8f4f3;
  color: #0f8b8d;
}

.button.danger {
  background: #fff0ee;
  color: #d84f45;
}

.chip-row {
  display: flex;
  gap: 14rpx;
  overflow-x: auto;
  white-space: nowrap;
  padding: 4rpx 0;
}

.chip {
  min-width: 128rpx;
  height: 60rpx;
  border-radius: 30rpx;
  padding: 0 24rpx;
  background: #eef4f2;
  color: #526466;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  box-sizing: border-box;
}

.section-head {
  margin: 28rpx 0 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title {
  font-size: 31rpx;
  font-weight: 800;
  color: #1d2b2f;
}

.section-action {
  font-size: 25rpx;
  color: #0f8b8d;
}
