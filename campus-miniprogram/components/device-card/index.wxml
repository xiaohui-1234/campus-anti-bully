<view class="device-card" bindtap="handleTap">
  <view class="device-main">
    <view class="device-icon {{onlineClass}}">
      <view class="device-icon-inner"></view>
    </view>
    <view class="device-body">
      <view class="device-name">{{device.device_name || device.deviceName || device.device_id || device.deviceId}}</view>
      <view class="device-id">{{device.location || '未设置地点'}} · {{device.device_id || device.deviceId}}</view>
    </view>
    <view class="status {{onlineClass}}">{{onlineText}}</view>
  </view>
  <view class="device-meta">
    <text>{{device.note || '暂无备注'}}</text>
    <text>{{device.last_online_time || device.lastOnlineTime || '暂无在线记录'}}</text>
  </view>
</view>
