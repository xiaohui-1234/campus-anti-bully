.empty {
  padding: 72rpx 32rpx;
  text-align: center;
  color: #7c8b8d;
  background: #ffffff;
  border-radius: 22rpx;
  box-shadow: 0 8rpx 24rpx rgba(33, 54, 59, 0.04);
  border: 1rpx solid #edf2ef;
}

.empty-title {
  font-size: 30rpx;
  color: #46575a;
  font-weight: 700;
}

.empty-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
}
