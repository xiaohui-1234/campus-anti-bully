<view class="event-card">
  <view class="event-body" bindtap="handleTap">
    <view class="event-head">
      <view class="event-title-wrap">
        <view class="event-dot {{event.read_status === 'UNREAD' || event.readStatus === 'UNREAD' ? 'hot' : 'read'}}"></view>
        <view class="event-title-main">
          <view class="event-type">{{event.event_type_text || event.event_type || event.eventType || '报警事件'}}</view>
          <view class="event-device">{{event.device_id || event.deviceId || '未知设备'}}</view>
        </view>
      </view>
      <view class="event-status {{event.read_status === 'UNREAD' || event.readStatus === 'UNREAD' ? 'unread' : 'read'}}">
        {{readText}}
      </view>
    </view>

    <view class="event-info">{{event.alarm_info_text || event.alarm_info || event.alarmInfo || '暂无报警信息'}}</view>

    <view class="event-meta">
      <text class="file-status {{canPlay ? 'ready' : 'pending'}}">{{fileText}}</text>
      <text class="event-time">{{event.event_time || event.eventTime}}</text>
    </view>
  </view>

  <view class="event-actions">
    <view class="play-button {{canPlay ? '' : 'disabled'}} {{isPlaying ? 'playing' : ''}}" catchtap="handlePlay">
      <view class="play-progress" style="{{progressStyle}}"></view>
      <view class="play-content">
        <view class="play-icon {{isPlaying ? 'pause' : ''}}"></view>
        <text>{{playText}}</text>
      </view>
    </view>
    <view class="detail-link" bindtap="handleTap">详情</view>
  </view>
</view>
