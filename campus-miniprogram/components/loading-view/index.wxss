.loading-slot {
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.loading {
  opacity: 0;
  text-align: center;
  color: #77858a;
  font-size: 26rpx;
  line-height: 48rpx;
  transition: opacity 0.12s ease;
  box-sizing: border-box;
  pointer-events: none;
}

.loading.is-visible {
  opacity: 1;
}
