.mask {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.42);
  display: flex;
  align-items: flex-end;
  z-index: 20;
}

.popup {
  width: 100%;
  max-height: 78vh;
  overflow: auto;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 28rpx 28rpx 42rpx;
  box-sizing: border-box;
}
