.toolbar {
  display: grid;
  grid-template-columns: 1fr 112rpx 172rpx;
  gap: 14rpx;
  margin-bottom: 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 18rpx;
  box-shadow: 0 8rpx 24rpx rgba(33, 54, 59, 0.035);
  border: 1rpx solid #edf2ef;
}

.toolbar-searching {
  grid-template-columns: 1fr 112rpx;
}

.search-button,
.add-button {
  height: 84rpx;
}

.form-input {
  margin-bottom: 18rpx;
}

.detail-handle {
  width: 72rpx;
  height: 8rpx;
  border-radius: 8rpx;
  background: #d6e0df;
  margin: 0 auto 24rpx;
}

.detail-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #1d2b2f;
  margin-bottom: 8rpx;
}

.detail-desc {
  color: #77858a;
  font-size: 25rpx;
  line-height: 1.5;
  margin-bottom: 24rpx;
}

.detail-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 20rpx;
}
