<view class="custom-nav" style="{{navStyle}}">
  <view class="custom-nav-title">校园防霸凌</view>
</view>

<view class="page" style="{{contentStyle}}">
  <view class="page-title">事件</view>
  <view class="page-subtitle">筛选、查看详情、标记已读和播放报警音频</view>

  <view class="filters">
    <view class="filter-top">
      <view class="search-bar">
        <view class="search-icon"></view>
        <input class="search-input" placeholder="搜索报警信息" value="{{filters.keyword}}" bindinput="onKeyword" confirm-type="search" bindconfirm="reload" />
      </view>
      <view class="filter-toggle" bindtap="toggleFilters">
        <text>{{filtersExpanded ? '收起' : '筛选'}}</text>
        <text class="toggle-arrow {{filtersExpanded ? 'is-open' : ''}}">⌄</text>
      </view>
    </view>

    <view wx:if="{{filtersExpanded}}" class="filter-panel">
      <view class="filter-grid">
        <picker mode="selector" range="{{deviceOptions}}" bindchange="onDevice">
          <view class="filter-field">
            <text class="field-name">设备</text>
            <text class="field-value">{{deviceLabel}}</text>
          </view>
        </picker>
        <view class="filter-field">
          <text class="field-name">类型</text>
          <input class="field-input" placeholder="事件类型" value="{{filters.event_type}}" bindinput="onEventType" confirm-type="search" bindconfirm="reload" />
        </view>
        <picker mode="selector" range="{{readOptions}}" bindchange="onReadStatus">
          <view class="filter-field">
            <text class="field-name">阅读</text>
            <text class="field-value">{{readLabel}}</text>
          </view>
        </picker>
        <picker mode="selector" range="{{fileOptions}}" bindchange="onFileStatus">
          <view class="filter-field">
            <text class="field-name">文件</text>
            <text class="field-value">{{fileLabel}}</text>
          </view>
        </picker>
        <picker mode="selector" range="{{pushOptions}}" bindchange="onPushStatus">
          <view class="filter-field">
            <text class="field-name">推送</text>
            <text class="field-value">{{pushLabel}}</text>
          </view>
        </picker>
        <picker mode="selector" range="{{sizeOptions}}" bindchange="onSize">
          <view class="filter-field">
            <text class="field-name">数量</text>
            <text class="field-value">{{sizeLabel}}</text>
          </view>
        </picker>
      </view>

      <view class="time-grid">
        <picker mode="date" value="{{startDate}}" bindchange="onStartDate">
          <view class="time-field">
            <text class="field-name">开始日期</text>
            <text class="field-value">{{startDate || '不限'}}</text>
          </view>
        </picker>
        <picker mode="time" value="{{startTime}}" bindchange="onStartTime">
          <view class="time-field">
            <text class="field-name">开始时间</text>
            <text class="field-value">{{startTime || '00:00'}}</text>
          </view>
        </picker>
        <picker mode="date" value="{{endDate}}" bindchange="onEndDate">
          <view class="time-field">
            <text class="field-name">结束日期</text>
            <text class="field-value">{{endDate || '不限'}}</text>
          </view>
        </picker>
        <picker mode="time" value="{{endTime}}" bindchange="onEndTime">
          <view class="time-field">
            <text class="field-name">结束时间</text>
            <text class="field-value">{{endTime || '23:59'}}</text>
          </view>
        </picker>
      </view>
    </view>

    <view class="filter-actions">
      <view class="button secondary filter-button" bindtap="resetFilters">重置</view>
      <view class="button filter-button" bindtap="reload">查询</view>
    </view>
  </view>

  <view class="section-head">
    <view class="section-title">事件列表</view>
    <view class="section-action" bindtap="reload">刷新</view>
  </view>

  <loading-view loading="{{loading}}" />
  <block wx:if="{{events.length}}">
    <event-card wx:for="{{events}}" wx:key="event_id" event="{{item}}" audio-state="{{audioState}}" bind:open="openDetail" bind:play="playAudio" />
    <view wx:if="{{hasMore}}" class="button secondary load-more" bindtap="loadMore">加载更多</view>
  </block>
  <empty-state wx:elif="{{!loading}}" title="暂无事件" desc="可调整筛选条件后重试" />

  <popup-panel visible="{{detailVisible}}" bind:close="closeDetail">
    <view wx:if="{{currentEvent}}" class="detail">
      <view class="detail-handle"></view>
      <view class="detail-title">{{currentEvent.event_type_text || currentEvent.event_type || currentEvent.eventType || '报警事件'}}</view>
      <view class="detail-card">
        <view class="detail-line"><text>设备</text><text>{{currentEvent.device_id || currentEvent.deviceId}}</text></view>
        <view class="detail-line"><text>信息</text><text>{{currentEvent.alarm_info_text || currentEvent.alarm_info || currentEvent.alarmInfo || '暂无'}}</text></view>
        <view class="detail-line"><text>文件</text><text>{{currentEvent.file_status || currentEvent.fileStatus}}</text></view>
        <view class="detail-line"><text>时间</text><text>{{currentEvent.event_time || currentEvent.eventTime}}</text></view>
      </view>
      <view class="detail-actions">
        <view class="button danger" bindtap="deleteEvent">删除事件</view>
        <view class="button" bindtap="markRead">确认已读</view>
      </view>
    </view>
  </popup-panel>
</view>
