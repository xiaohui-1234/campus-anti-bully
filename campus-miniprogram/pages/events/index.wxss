.filters {
  margin-bottom: 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 18rpx;
  box-shadow: 0 8rpx 24rpx rgba(33, 54, 59, 0.035);
  border: 1rpx solid #edf2ef;
}

.filter-top {
  display: grid;
  grid-template-columns: 1fr 136rpx;
  gap: 14rpx;
  align-items: center;
}

.filter-toggle {
  height: 84rpx;
  border-radius: 18rpx;
  background: #e8f4f3;
  color: #0f8b8d;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 26rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.toggle-arrow {
  line-height: 1;
  transition: transform 0.16s ease;
}

.toggle-arrow.is-open {
  transform: rotate(180deg);
}

.filter-panel {
  padding-top: 18rpx;
}

.filter-grid,
.time-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.time-grid {
  margin-top: 14rpx;
}

.filter-field,
.time-field {
  min-height: 84rpx;
  border-radius: 18rpx;
  background: #f1f6f4;
  padding: 12rpx 18rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.field-name {
  color: #7c8b8d;
  font-size: 22rpx;
  line-height: 1.2;
}

.field-value,
.field-input {
  margin-top: 8rpx;
  min-width: 0;
  color: #263238;
  font-size: 26rpx;
  line-height: 1.25;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.field-input {
  height: 34rpx;
}

.filter-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 18rpx;
}

.filter-button {
  height: 76rpx;
  border-radius: 18rpx;
}

.load-more {
  margin: 20rpx 0 40rpx;
}

.detail-handle {
  width: 72rpx;
  height: 8rpx;
  border-radius: 8rpx;
  background: #d6e0df;
  margin: 0 auto 24rpx;
}

.detail-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #1d2b2f;
  margin-bottom: 24rpx;
}

.detail-card {
  background: #f1f6f4;
  border-radius: 22rpx;
  padding: 8rpx 22rpx;
}

.detail-line {
  font-size: 28rpx;
  color: #46575a;
  min-height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  border-bottom: 1rpx solid #dfe8e5;
}

.detail-line:last-child {
  border-bottom: 0;
}

.detail-line text:first-child {
  color: #7c8b8d;
  flex: 0 0 auto;
}

.detail-line text:last-child {
  text-align: right;
  min-width: 0;
}

.detail-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 28rpx;
}
