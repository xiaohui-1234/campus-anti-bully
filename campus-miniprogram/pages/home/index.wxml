<view class="custom-nav" style="{{navStyle}}">
  <view class="custom-nav-title">校园防霸凌</view>
</view>

<view class="page home-page" style="{{contentStyle}}">
  <view class="home-header">
    <view>
      <view class="page-title">今日守护</view>
      <view class="page-subtitle">实时同步已绑定设备的报警与在线状态</view>
    </view>
    <view class="header-badge">在线 {{onlineTotal}}</view>
  </view>

  <view class="hero">
    <view>
      <view class="hero-kicker">待关注事件</view>
      <view class="hero-title">{{events.length}}</view>
      <view class="hero-subtitle">新报警会自动置顶，离线后可补拉</view>
    </view>
    <view class="hero-status">
      <view class="pulse"></view>
      <text>WebSocket</text>
    </view>
  </view>

  <view class="summary">
    <view class="summary-item">
      <view class="summary-mark bind"></view>
      <view class="num">{{devices.length}}</view>
      <view class="label">已绑定</view>
    </view>
    <view class="summary-item">
      <view class="summary-mark event"></view>
      <view class="num">{{events.length}}</view>
      <view class="label">待关注</view>
    </view>
  </view>

  <view class="quick-actions">
    <navigator url="/pages/devices/index" open-type="switchTab" class="quick-action">绑定设备</navigator>
    <navigator url="/pages/events/index" open-type="switchTab" class="quick-action">查看事件</navigator>
    <navigator url="/pages/profile/index" open-type="switchTab" class="quick-action">个人资料</navigator>
  </view>

  <view class="section-head">
    <view class="section-title">最新事件</view>
    <navigator url="/pages/events/index" open-type="switchTab" class="section-action">全部</navigator>
  </view>

  <loading-view loading="{{loading}}" />
  <block wx:if="{{events.length}}">
    <event-card wx:for="{{events}}" wx:key="event_id" event="{{item}}" audio-state="{{audioState}}" bind:open="openEvent" bind:play="playAudio" />
  </block>
  <empty-state wx:elif="{{!loading}}" title="暂无新事件" desc="已通过 HTTP 补拉和 WebSocket 同步" />
</view>
