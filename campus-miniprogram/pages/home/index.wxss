.home-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.header-badge {
  margin-top: 16rpx;
  height: 52rpx;
  border-radius: 26rpx;
  padding: 0 20rpx;
  background: #e7f4ed;
  color: #2f7d57;
  display: flex;
  align-items: center;
  font-size: 24rpx;
  flex: 0 0 auto;
}

.hero {
  min-height: 230rpx;
  background: #0f8b8d;
  border-radius: 30rpx;
  padding: 34rpx;
  color: #ffffff;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-sizing: border-box;
  margin-bottom: 24rpx;
  box-shadow: 0 18rpx 42rpx rgba(15, 139, 141, 0.18);
}

.hero-kicker {
  font-size: 25rpx;
  opacity: 0.86;
}

.hero-title {
  margin-top: 8rpx;
  font-size: 76rpx;
  font-weight: 800;
  line-height: 1;
}

.hero-subtitle {
  margin-top: 16rpx;
  font-size: 26rpx;
  opacity: 0.9;
}

.hero-status {
  height: 58rpx;
  border-radius: 29rpx;
  padding: 0 20rpx;
  background: rgba(255, 255, 255, 0.16);
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 23rpx;
}

.pulse {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #b9f6d0;
}

.summary {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.summary-item {
  position: relative;
  background: #ffffff;
  border-radius: 22rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(33, 54, 59, 0.045);
  border: 1rpx solid #edf2ef;
}

.summary-mark {
  width: 42rpx;
  height: 42rpx;
  border-radius: 14rpx;
  margin-bottom: 14rpx;
}

.summary-mark.bind {
  background: #e8f4f3;
}

.summary-mark.event {
  background: #fff0ee;
}

.num {
  font-size: 42rpx;
  font-weight: 800;
  color: #1d2b2f;
}

.label {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #7c8b8d;
}

.quick-actions {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-bottom: 8rpx;
}

.quick-action {
  height: 74rpx;
  border-radius: 22rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #0f8b8d;
  font-size: 26rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 22rpx rgba(33, 54, 59, 0.04);
  border: 1rpx solid #edf2ef;
}
