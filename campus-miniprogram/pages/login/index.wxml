<view class="login-page">
  <view class="custom-nav" style="{{navStyle}}">
    <view class="custom-nav-title">校园防霸凌</view>
  </view>

  <view class="main-content" style="{{contentStyle}}">
    <view class="welcome-block">
      <view class="welcome-title">欢迎登录</view>
      <view class="welcome-desc">已注册用户可直接进入，新用户首次登录后完善头像和微信名称</view>
      <view class="wechat-login {{loading ? 'is-loading' : ''}}" bindtap="openProfileDialog">
        <view class="wechat-icon">
          <view class="bubble one"></view>
          <view class="bubble two"></view>
        </view>
        <text>{{loading && !profileVisible ? '登录中...' : '微信一键登录'}}</text>
      </view>
    </view>

    <view class="agreement">登录即表示同意 <text>《用户协议》</text> 和 <text>《隐私政策》</text></view>
  </view>

  <view wx:if="{{profileVisible}}" class="modal-mask" style="{{modalStyle}}">
    <view class="profile-dialog" style="{{dialogStyle}}">
      <view class="dialog-title">完善登录资料</view>
      <view class="dialog-desc">请选择头像并填写微信名称，确认后完成登录</view>
      <loading-view loading="{{loading}}" />

      <view class="field-label">头像</view>
      <button class="avatar-button" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image wx:if="{{avatarUrl}}" class="avatar" src="{{avatarUrl}}" mode="aspectFill"></image>
        <view wx:else class="avatar avatar-empty">
          <view class="avatar-head"></view>
          <view class="avatar-body"></view>
        </view>
      </button>
      <view class="avatar-tip">点击头像选择你的微信头像</view>

      <view class="field-label nickname-label">微信名称</view>
      <input
        class="nickname-input"
        type="nickname"
        placeholder="请输入微信名称"
        value="{{nickname}}"
        bindinput="onNickname"
      />
      <view class="nickname-tip">支持使用微信昵称快捷填写</view>

      <view class="profile-warning">请先完成头像与微信名称填写</view>

      <view class="dialog-actions">
        <view class="dialog-button cancel" bindtap="closeProfileDialog">取消</view>
        <view class="dialog-button confirm {{canSubmit ? 'active' : ''}}" bindtap="submit">确定登录</view>
      </view>
    </view>
  </view>
</view>
