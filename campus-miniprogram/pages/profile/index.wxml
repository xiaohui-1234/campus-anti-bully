<view class="custom-nav" style="{{navStyle}}">
  <view class="custom-nav-title">校园防霸凌</view>
</view>

<view class="page" style="{{contentStyle}}">
  <view class="page-title">个人</view>
  <view class="page-subtitle">管理登录资料、联系方式和账号状态</view>
  <loading-view loading="{{loading}}" />
  <view class="profile-card">
    <image wx:if="{{form.avatar_url || form.avatarUrl}}" class="avatar" src="{{form.avatar_url || form.avatarUrl}}" mode="aspectFill"></image>
    <view wx:else class="avatar avatar-empty">我</view>
    <view class="profile-info">
      <view class="name">{{form.nickname || '未登录'}}</view>
      <view class="role">{{roleLabel}} · {{form.user_id || form.userId || '未获取用户编号'}}</view>
    </view>
  </view>

  <view class="panel form">
    <view class="form-title">基础资料</view>
    <input class="input form-input" placeholder="昵称" value="{{form.nickname}}" bindinput="onNickname" />
    <input class="input form-input" placeholder="手机号" value="{{form.phone}}" bindinput="onPhone" />
    <input class="input form-input" placeholder="邮箱" value="{{form.email}}" bindinput="onEmail" />
    <view class="button" bindtap="saveProfile">保存资料</view>
  </view>

  <view class="panel action-list">
    <view class="action-item" bindtap="chooseAvatar">
      <text>上传头像</text>
      <text class="arrow">›</text>
    </view>
    <view class="action-item" bindtap="login">
      <text>重新登录</text>
      <text class="arrow">›</text>
    </view>
    <view class="action-item danger-text" bindtap="logout">
      <text>退出登录</text>
      <text class="arrow">›</text>
    </view>
  </view>
</view>
