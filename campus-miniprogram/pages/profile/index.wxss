.profile-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
  min-height: 174rpx;
  background: #0f8b8d;
  border-radius: 30rpx;
  padding: 28rpx;
  box-sizing: border-box;
  color: #ffffff;
  box-shadow: 0 18rpx 42rpx rgba(15, 139, 141, 0.16);
}

.avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 64rpx;
  background: rgba(255, 255, 255, 0.24);
  flex: 0 0 auto;
}

.avatar-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 800;
  border: 2rpx solid rgba(255, 255, 255, 0.28);
}

.profile-info {
  min-width: 0;
}

.name {
  font-size: 34rpx;
  font-weight: 800;
  color: #ffffff;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.role {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.82);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.form-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #1d2b2f;
  margin-bottom: 20rpx;
}

.form-input {
  margin-bottom: 18rpx;
}

.action-list {
  margin-top: 24rpx;
  padding: 0 24rpx;
}

.action-item {
  min-height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #e7eeeb;
  color: #263238;
  font-size: 28rpx;
}

.action-item:last-child {
  border-bottom: 0;
}

.arrow {
  color: #95a3a2;
  font-size: 42rpx;
  line-height: 1;
}

.danger-text {
  color: #d84f45;
}
