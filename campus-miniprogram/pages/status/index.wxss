.stats {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.stat {
  background: #ffffff;
  border-radius: 22rpx;
  min-height: 200rpx;
  padding: 26rpx;
  box-sizing: border-box;
  box-shadow: 0 8rpx 24rpx rgba(33, 54, 59, 0.045);
  border: 1rpx solid #edf2ef;
}

.stat-icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 14rpx;
  background: #e8f4f3;
  margin-bottom: 18rpx;
}

.stat-icon.online {
  background: #e7f4ed;
}

.stat-icon.today {
  background: #fff6e8;
}

.stat-icon.unread {
  background: #fff0ee;
}

.num {
  font-size: 52rpx;
  font-weight: 800;
  color: #1d2b2f;
}

.label {
  margin-top: 10rpx;
  color: #7c8b8d;
  font-size: 26rpx;
}

.status-note {
  margin-top: 24rpx;
}

.note-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #1d2b2f;
}

.note-text {
  margin-top: 12rpx;
  color: #6f7f82;
  font-size: 26rpx;
  line-height: 1.65;
}
