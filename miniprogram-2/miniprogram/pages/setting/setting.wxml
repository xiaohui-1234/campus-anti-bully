<!--pages/setting/setting.wxml-->
<view class="form-container">
  <view class="form-item">
    <label class="form-label">设备名称：</label>
    <input 
      class="form-input" 
      placeholder="请输入设备名称" 
      bindinput="onDeviceNameInput"
      value="{{deviceName}}"
    />
  </view>

  <view class="form-item">
    <label class="form-label">设备ID：</label>
    <input 
      class="form-input" 
      placeholder="请输入设备ID" 
      bindinput="onDeviceIdInput"
      value="{{deviceId}}"
    />
  </view>

  <view class="form-item">
    <label class="form-label">设备地点：</label>
    <input 
      class="form-input" 
      placeholder="请输入设备地点" 
      bindinput="onDevicePlaceInput"
      value="{{devicePlace}}"
    />
  </view>

  <button class="submit-btn" bindtap="submitForm">提交</button>
</view>